{
    "name": "pablofarias19/mapita",
    "description": "Aplicación de mapeo de negocios locales con Leaflet.js",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "dompdf/dompdf": "^3.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Core\\": "core/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
